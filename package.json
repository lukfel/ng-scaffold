{
  "name": "ng-scaffold-app",
  "version": "22.1.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch false",
    "lint": "ng lint --fix",
    "deploy": "ng deploy --project ng-scaffold-app --base-href /ng-scaffold/ --repo https://github.com/lukfel/ng-scaffold.git",
    "lib:build": "ng build ng-scaffold --configuration production",
    "lib:watch": "ng build ng-scaffold --watch --configuration development",
    "lib:schematics": "cd projects/ng-scaffold && npm run build && npm run postbuild",
    "lib:publish": "npm publish ./dist/ng-scaffold --access public"
  },
  "dependencies": {
    "@angular/animations": "^22.0.5",
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/material": "^22.0.3",
    "@angular/platform-browser": "^22.0.5",
    "@angular/router": "^22.0.5",
    "@angular/service-worker": "^22.0.5",
    "@lukfel/ng-scaffold": "file:dist/ng-scaffold",
    "marked": "^18.0.0",
    "ngx-markdown": "^22.0.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@eslint/js": "^9.39.4",
    "angular-cli-ghpages": "^3.1.0",
    "angular-eslint": "^22.0.0",
    "copyfiles": "~2.4.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unused-imports": "^4.1.4",
    "happy-dom": "^20.8.4",
    "ng-packagr": "22.0.1",
    "prettier": "^3.4.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.0"
  }
}
